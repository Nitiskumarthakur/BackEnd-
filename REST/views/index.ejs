<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Posts</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Quora Post</h1>
    <%for (post of posts) {%>

        <div class="posts">
            <h3 class="user">@<%= post.username%></h3>
            <p class="content"><%= post.content %></p>
            <a href="http://localhost:4040/posts/<%=post.id%>">se-in-detail</a> &nbsp; &nbsp;
            <a href="http://localhost:4040/posts/<%=post.id%>/edit">Edit</a>
            <form method="post" action="/posts/<%=post.id%>?_method=DELETE">
                <button>Delete</button>
            </form>
        </div> 

    <%}%>
    <form method="get" action="http://localhost:4040/posts/new">
        <button>New Post</button>
    </form>
</body>
</html>